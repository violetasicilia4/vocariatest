{
  "name": "vocaria",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "check": "npm run lint && npm run test && npm run build",
    "check:full": "npm run lint && npm run test && npm run build && npm run test:e2e",
    "diagnose": "tsx scripts/diagnose.ts",
    "diagnose:adaptive": "tsx scripts/diagnose-adaptive.ts",
    "og": "npm i -D --no-save @resvg/resvg-js && node scripts/generate-og.mjs",
    "hero:webp": "npm i -D --no-save sharp && node scripts/generate-hero-webp.mjs"
  },
  "dependencies": {
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.1.14",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.4",
    "jsdom": "^25.0.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  }
}
