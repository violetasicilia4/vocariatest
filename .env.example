# APP_URL: URL pública del sitio. Si falta, se deriva del request en las
# funciones de /api. Útil para los back_urls de Mercado Pago.
APP_URL="https://your-domain.com"

# ── Supabase: captura de leads y resultados ──────────────────────────────────
# Crear proyecto en https://supabase.com → Settings → API.
# Ejecutar supabase/schema.sql en el SQL Editor antes del primer deploy.
# IMPORTANTE: estas variables van expuestas al cliente (prefijo VITE_).
# La anon key sólo puede INSERTAR (ver RLS en schema.sql); está bien que sea pública.
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# ── Mercado Pago: cobro de los informes (planes pagos) ───────────────────────
# 🔒 PAGOS DESACTIVADOS POR DEFECTO. Reglas (no romper):
#   - `PAYMENTS_ENABLED` es el switch SERVER-SIDE real del cobro (endpoints /api).
#   - `VITE_PAYMENTS_ENABLED` es SÓLO de UI (build-time): NO usar VITE_ para
#     activar cobros reales; una variable de frontend nunca debe habilitar plata.
#   - NUNCA poner `PAYMENTS_ENABLED="true"` hasta cerrar todos los TODO(mp) de
#     api/ (firma de webhook, monto/plan, external_reference y persistencia
#     server-side, idempotencia, SUPABASE_SERVICE_KEY).
#
# El Access Token es SECRETO y va SÓLO server-side (funciones en /api). Nunca con
# prefijo VITE_. Sacalo de Mercado Pago → Tus integraciones → Credenciales.
# Para probar el flujo completo sin cobrar, usá las credenciales de PRUEBA (TEST).
MP_ACCESS_TOKEN="APP_USR-xxxxxxxx-xxxx-xxxx-xxxxxxxxxxxx"

# Habilita el cobro real en el FRONTEND (build-time). Si no es "true", la UI usa
# el flujo de "reserva" (sin cobro).
VITE_PAYMENTS_ENABLED="false"

# Habilita el cobro real en el SERVER (kill switch de los endpoints de /api). Sin
# prefijo VITE_ a propósito: el cobro real exige una decisión explícita del lado
# del server, no alcanza con la variable de build del frontend.
#   ⚠️ NO PRODUCTIVO: la integración de Mercado Pago es un esqueleto. Antes de
#   poner esto en "true" hay que endurecer /api (firma del webhook, validación de
#   monto/plan, external_reference y persistencia server-side, idempotencia y
#   SUPABASE_SERVICE_KEY). Mientras esté en "false"/ausente, create-preference,
#   verify-payment y mp-webhook quedan inertes y no cobran dinero real.
PAYMENTS_ENABLED="false"

# (Opcional) Para que el webhook registre las compras en Supabase con permisos de
# escritura propios, usá la service_role key server-side. Si no, usa la anon key.
# SUPABASE_URL="https://your-project.supabase.co"
# SUPABASE_SERVICE_KEY="your-service-role-key"
