# APP_URL: URL pública del sitio. Si falta, se deriva del request en las
# funciones de /api. Útil para los back_urls de Mercado Pago.
APP_URL="https://your-domain.com"

# ── Supabase: captura de leads y resultados ──────────────────────────────────
# Crear proyecto en https://supabase.com → Settings → API.
# Ejecutar supabase/schema.sql en el SQL Editor antes del primer deploy.
# IMPORTANTE: estas variables van expuestas al cliente (prefijo VITE_).
# La anon key sólo puede INSERTAR (ver RLS en schema.sql); está bien que sea pública.
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# ── Mercado Pago: cobro de los informes (planes pagos) ───────────────────────
# El Access Token es SECRETO y va SÓLO server-side (funciones en /api). Nunca con
# prefijo VITE_. Sacalo de Mercado Pago → Tus integraciones → Credenciales.
# Para probar el flujo completo sin cobrar, usá las credenciales de PRUEBA (TEST).
MP_ACCESS_TOKEN="APP_USR-xxxxxxxx-xxxx-xxxx-xxxxxxxxxxxx"

# Habilita el cobro real en el frontend. Si no es "true", la UI usa el flujo de
# "reserva" (sin cobro). Setear junto con MP_ACCESS_TOKEN al ir a producción.
VITE_PAYMENTS_ENABLED="false"

# (Opcional) Para que el webhook registre las compras en Supabase con permisos de
# escritura propios, usá la service_role key server-side. Si no, usa la anon key.
# SUPABASE_URL="https://your-project.supabase.co"
# SUPABASE_SERVICE_KEY="your-service-role-key"
